# ─────────────────────────────────────────────────────────────────────────────
# Electra Frontend — Environment Variables Template
# Copy to .env.local for local development (never commit .env.local).
# In production these are set as GitHub Actions secrets (see deploy.yml).
# ─────────────────────────────────────────────────────────────────────────────

# Backend API base URL (include /api/v1 path)
# Dev: http://localhost:8000/api/v1
# Prod: https://electra-api-368835973060.us-central1.run.app/api/v1
VITE_API_BASE_URL=http://localhost:8000/api/v1

# Firebase configuration (get from Firebase Console → Project Settings → Your apps)
VITE_FIREBASE_API_KEY=AIzaSy-your-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:abcdef1234567890
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Maps JavaScript API key
# Restrict this key to your domain in Google Cloud Console → APIs & Services → Credentials
VITE_GOOGLE_MAPS_API_KEY=AIzaSy-your-maps-api-key-here
