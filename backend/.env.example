# ─────────────────────────────────────────────────────────────────────────────
# Electra Backend — Environment Variables Template
# Copy this file to .env and fill in your actual values.
# NEVER commit .env — only .env.example is committed to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Google Cloud project ID (same as Firebase project ID)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Path to Firebase service account JSON key file (LOCAL DEVELOPMENT ONLY)
# In production (Cloud Run), leave empty — Application Default Credentials are used instead.
# NEVER commit the actual key file. Add it to .gitignore.
FIREBASE_SERVICE_ACCOUNT_KEY=./serviceAccountKey.json

# Dialogflow CX agent ID (the UUID of your agent, not the project ID)
# Leave empty to disable chat and return a static helpful message instead.
DIALOGFLOW_AGENT_ID=

# Dialogflow CX location (usually "global"; some agents use a region like "us-central1")
DIALOGFLOW_LOCATION=global

# Application environment — controls security headers, docs visibility, and logging
# Values: "development" | "production"
ENVIRONMENT=development

# Comma-separated list of allowed frontend origins for CORS
# In production, set this to your Firebase Hosting URL
ALLOWED_ORIGINS=http://localhost:5173

# Secret key — at least 32 random characters
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-string-at-least-32-chars

# Default rate limit (requests per minute, per IP) for all endpoints
# Individual endpoints may override this with their own @limiter.limit() decorator
RATE_LIMIT_PER_MINUTE=120
